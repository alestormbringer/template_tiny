# ── SERVER ──────────────────────────────────────────
TINYAGI_PORT=8090
LOG_LEVEL=INFO

# ── MODELLO LLM (Groq cloud — OpenAI-compatible) ─────
OLLAMA_MODEL=llama-3.1-8b-instant
OLLAMA_QUALITY_MODEL=llama-3.3-70b-versatile
# Tier 1 (fast/JSON agents):  llama-3.1-8b-instant
# Tier 2 (quality/writing):   llama-3.3-70b-versatile

# ── GUMROAD ─────────────────────────────────────────
# Ottieni la key su: https://app.gumroad.com/settings/advanced
GUMROAD_API_KEY=

# ── ETSY ────────────────────────────────────────────
# Usato come fallback quando Gumroad raggiunge il limite di 10 prodotti/giorno
# 1. Crea un'app su: https://www.etsy.com/developers/register
# 2. Ottieni access_token e refresh_token via OAuth2
# 3. Trova il tuo shop_id su: https://openapi.etsy.com/v3/application/users/me/shops
ETSY_API_KEY=
ETSY_SHOP_ID=
ETSY_ACCESS_TOKEN=
ETSY_REFRESH_TOKEN=

# ── NOTION ──────────────────────────────────────────
# Crea un'integration su: https://www.notion.so/my-integrations
NOTION_API_KEY=
# ID del workspace Notion dove creare i template
NOTION_WORKSPACE_ID=

# ── LLM API (Groq) ──────────────────────────────────
# Crea un account su: https://console.groq.com
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# ── WEB SEARCH (SearXNG — self-hosted, zero costi) ──
# Nessuna key necessaria, gira come container Docker
SEARXNG_BASE_URL=http://searxng:8080
