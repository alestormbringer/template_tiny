# ── SERVER ──────────────────────────────────────────
TINYAGI_PORT=8090
LOG_LEVEL=INFO

# ── MODELLO LLM (Ollama locale) ──────────────────────
OLLAMA_MODEL=llama3.1:8b
# Modelli consigliati per 8GB RAM:
#   llama3.1:8b   → ~5GB  (default, qualità ottima)
#   mistral:7b    → ~4.5GB
#   llama3.2:3b   → ~2GB  (più veloce, qualità buona)

# ── GUMROAD ─────────────────────────────────────────
# Ottieni la key su: https://app.gumroad.com/settings/advanced
GUMROAD_API_KEY=

# ── ETSY ────────────────────────────────────────────
# Usato come fallback quando Gumroad raggiunge il limite di 10 prodotti/giorno
# 1. Crea un'app su: https://www.etsy.com/developers/register
# 2. Ottieni access_token e refresh_token via OAuth2
# 3. Trova il tuo shop_id su: https://openapi.etsy.com/v3/application/users/me/shops
ETSY_API_KEY=
ETSY_SHOP_ID=
ETSY_ACCESS_TOKEN=
ETSY_REFRESH_TOKEN=

# ── NOTION ──────────────────────────────────────────
# Crea un'integration su: https://www.notion.so/my-integrations
NOTION_API_KEY=
# ID del workspace Notion dove creare i template
NOTION_WORKSPACE_ID=

# ── CODEX CLI → punta a Ollama locale (zero costi) ──
# Codex CLI è open source e usa l'API OpenAI-compatible di Ollama
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://ollama:11434/v1

# ── URL PUBBLICO DEL VPS (per servire i PDF dei prodotti) ────
# Imposta con l'IP pubblico del tuo VPS o dominio, porta 3000
# Es: PUBLIC_URL=http://123.45.67.89:3000
PUBLIC_URL=

# ── WEB SEARCH (SearXNG — self-hosted, zero costi) ──
# Nessuna key necessaria, gira come container Docker
SEARXNG_BASE_URL=http://searxng:8080
